# Supabase transaction pooler (port 6543) — used by Vercel serverless functions
# pgbouncer=true is required for Prisma to work with PgBouncer in transaction mode
DATABASE_URL="postgresql://postgres:<password>@db.<project>.supabase.co:6543/postgres?pgbouncer=true&connection_limit=1"

# Supabase direct connection (port 5432) — used only for prisma migrate/db push
DIRECT_URL="postgresql://postgres:<password>@db.<project>.supabase.co:5432/postgres"

# Generate a strong random string: openssl rand -base64 32
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
